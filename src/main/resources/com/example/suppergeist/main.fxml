<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.suppergeist.ui.MainController"
            prefHeight="400.0" prefWidth="600.0">
    <top>
        <HBox spacing="10" styleClass="header">
            <ImageView fitHeight="105" preserveRatio="true" blendMode="LIGHTEN">
                <image>
                    <Image url="@ghost_chef.png"/>
                </image>
            </ImageView>
            <Label text="Suppergeist"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Prefs" onAction="#togglePrefs"/>
        </HBox>
    </top>
    <center>
        <TabPane>
            <tabs>
                <Tab text="Meal Plan" closable="false">
                    <content>
                        <VBox>
                            <HBox spacing="10">
                                <Button onAction="#goToPreviousWeek">Prev</Button>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="weekLabel"></Label>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button onAction="#goToNextWeek">Next</Button>
                            </HBox>
                            <GridPane fx:id="mealPlanGrid" hgap="10" vgap="10"/>
                        </VBox>
                    </content>
                </Tab>
                <fx:include fx:id="shoppingList" source="shopping-list.fxml"/>
            </tabs>
        </TabPane>
    </center>
    <right>
        <fx:include fx:id="preferencesSidebar" source="preferences-sidebar.fxml"/>
    </right>
    <bottom>
        <HBox spacing="10" styleClass="footer">
            <Label text="Buttons will go here later"/>
        </HBox>
    </bottom>
</BorderPane>
